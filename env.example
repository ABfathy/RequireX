NEXT_PUBLIC_APP_URL=http://localhost:3000

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true"
UPLOADTHING_TOKEN=

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk routing — page locations
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Fallback redirect: used when no ?redirect_url param is present
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app
SEED_USER_ID=

# Force redirect: always overrides any other redirect — uncomment to lock down
# NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/app
# NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/app

GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
BRIEF_GENERATION_ASYNC=0

INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=1
